{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "会議録抽出スキーマ v1",
  "description": "日本語会議トランスクリプトから抽出する構造化情報。モデルにはこの形式のJSONのみを出力させる。",
  "type": "object",
  "required": ["decisions", "action_items", "key_numbers"],
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "description": "会議で確定した決定事項。検討中・保留のものは含めない。",
      "items": {
        "type": "object",
        "required": ["id", "content", "decided_by"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^D[0-9]+$",
            "description": "D1 から始まる連番"
          },
          "content": {
            "type": "string",
            "description": "決定内容を1文で。何がどう決まったかが分かるように書く。"
          },
          "decided_by": {
            "type": "string",
            "description": "その決定を下した／承認した人物の氏名。合議で明確な発話者がいない場合は最終的に承認した進行役の氏名。"
          }
        }
      }
    },
    "action_items": {
      "type": "array",
      "description": "会議後に実行すべきタスク。担当者と期限が紐づくもの。",
      "items": {
        "type": "object",
        "required": ["id", "task", "assignee", "due"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^A[0-9]+$",
            "description": "A1 から始まる連番"
          },
          "task": {
            "type": "string",
            "description": "実行すべき内容を1文で。"
          },
          "assignee": {
            "type": "string",
            "description": "担当者の氏名。会議中に担当が変更された場合は最終的な担当者。"
          },
          "due": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
            "description": "期限。YYYY-MM-DD 形式。「来週金曜」等の相対表現は会議日付を基準に絶対日付へ解決する。期限の言及がない場合はこの項目自体を出力しない。"
          }
        }
      }
    },
    "key_numbers": {
      "type": "array",
      "description": "会議で言及された重要な数値。金額・件数・日付・時間など。",
      "items": {
        "type": "object",
        "required": ["id", "label", "value"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^N[0-9]+$",
            "description": "N1 から始まる連番"
          },
          "label": {
            "type": "string",
            "description": "その数値が何を指すかの短いラベル（例: 対象拠点数）"
          },
          "value": {
            "type": "string",
            "description": "数値と単位（例: 14拠点, 600万円, 2026-10-15）。会議中に訂正された場合は訂正後の最終値。"
          }
        }
      }
    }
  }
}
